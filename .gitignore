# SharePoint SSO Demo - Git Ignore File

# Folders starting with underscore
_*/

# Sensitive Configuration Files
# IMPORTANT: Never commit these files with real credentials
config.local.js
secrets.js
.env
.env.local

# Node modules (if using npm)
node_modules/
package-lock.json

# IDE and Editor Files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Build and Distribution
dist/
build/
*.min.js
*.min.css

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary Files
tmp/
temp/
*.tmp

# OS Files
Thumbs.db
.DS_Store
desktop.ini

# Backup Files
*.bak
*.backup
*~

# Test Coverage
coverage/
.nyc_output/

# Optional: Uncomment if you want to ignore documentation
# Docs/
# *.md

# Keep these files
!README.md
!.gitignore